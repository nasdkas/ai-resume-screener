# === LLM 后端选择 ===
# 可选值: openai | ollama
LLM_PROVIDER=openai

# === Ollama 配置 (LLM_PROVIDER=ollama 时生效) ===
#OLLAMA_HOST=http://localhost:11434
#LLM_MODEL=qwen3.5:4b

# === JSON 模式 (仅 Ollama 生效) ===
# 启用后 Ollama 将使用 JSON Schema 约束输出格式，提高结构化输出稳定性
#LLM_JSON_MODE=false

# === 思考模式 (仅 Ollama 生效) ===
# 启用后评分时 LLM 将开启思考模式，提升推理质量但增加耗时
#LLM_THINK_MODE=false

# === OpenAI 兼容配置 (LLM_PROVIDER=openai 时生效) ===
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-3.5-turbo
